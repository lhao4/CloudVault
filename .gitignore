# ───────────────────────────────────────────
# AI
# ───────────────────────────────────────────
.claude/
.codex/
# ───────────────────────────────────────────
# OS / Editor
# ───────────────────────────────────────────
.DS_Store
Thumbs.db
*.swp
*.swo
*~
.idea/
.vscode/
*.iml

# CLion 构建目录（CLion 默认用 cmake-build-* 而非 build/）
cmake-build-debug/
cmake-build-release/
cmake-build-*/

# ───────────────────────────────────────────
# CMake
# ───────────────────────────────────────────
build/
**/build/
CMakeFiles/
CMakeCache.txt
cmake_install.cmake
CTestTestfile.cmake
_deps/
*.cmake
!cmake/
!cmake/*.cmake

# ───────────────────────────────────────────
# C/C++ Build Artifacts
# ───────────────────────────────────────────
*.o
*.obj
*.a
*.lib
*.so
*.so.*
*.dylib
*.dll
*.exe
*.out
*.dSYM/

# ───────────────────────────────────────────
# Qt
# ───────────────────────────────────────────
# Qt Creator 用户文件
*.pro.user
*.pro.user.*
*.qbs.user
*.qmake.stash
*.qtc_clangd/
.qtcreator/

# Qt 自动生成的文件（CMake AUTOMOC/AUTOUIC/AUTORCC 产物）
moc_*.cpp
moc_*.h
qrc_*.cpp
ui_*.h

# ───────────────────────────────────────────
# Compile Commands（clangd 工具链）
# ───────────────────────────────────────────
# 通常由 cmake -DCMAKE_EXPORT_COMPILE_COMMANDS=ON 生成
# 保留根目录的符号链接版本（如果有），忽略 build/ 内的原始文件
compile_commands.json

# ───────────────────────────────────────────
# Server 运行时产物
# ───────────────────────────────────────────
logs/
server.json
server/logs/
server/filesys/
server/config/server.json
client/config/client.json

# ───────────────────────────────────────────
# 证书与密钥（绝不提交）
# ───────────────────────────────────────────
*.pem
*.key
*.crt
*.p12
*.pfx
certs/

# ───────────────────────────────────────────
# 环境变量与密码文件（绝不提交）
# ───────────────────────────────────────────
.env
.env.*
secrets/

# ───────────────────────────────────────────
# MkDocs 构建产物
# ───────────────────────────────────────────
site/

# ───────────────────────────────────────────
